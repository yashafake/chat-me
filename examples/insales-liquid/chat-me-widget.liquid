{%- comment -%}
  Minimal InSales / Liquid integration for chat-me.

  For a styled black/white storefront button that replaces Telegram,
  see `examples/insales-liquid/iwant-chat-widget.liquid`.
{%- endcomment -%}

<script src="https://chat.black8.tech/widget/chat-me-widget.js" defer></script>
<script>
  window.addEventListener("load", function () {
    if (!window.ChatMeWidget) return;

    window.ChatMeWidget.init({
      projectKey: "insales-store",
      apiBaseUrl: "https://chat.black8.tech",
      locale: "ru",
      theme: {
        accentColor: "#111111",
        buttonLabel: "Чат",
        position: "bottom-right",
        borderRadius: 24
      }
    });
  });
</script>

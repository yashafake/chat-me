{%- comment -%}
  InSales / Liquid integration snippet for chat-me
  Requirements before enabling:
  1. change project status to active
  2. set the real storefront host in chat_projects.allowed_origins
{%- endcomment -%}

<script src="https://chat.black8.tech/widget/chat-me-widget.js" defer></script>
<script>
  window.addEventListener("load", function () {
    if (!window.ChatMeWidget) return;

    window.ChatMeWidget.init({
      projectKey: "insales-store",
      apiBaseUrl: "https://chat.black8.tech",
      locale: "ru",
      theme: {
        accentColor: "#d8b774",
        buttonLabel: "Связаться",
        position: "bottom-left",
        borderRadius: 22
      }
    });
  });
</script>

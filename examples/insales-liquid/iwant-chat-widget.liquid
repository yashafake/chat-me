    function getLocale() {
      var htmlLang = (document.documentElement.getAttribute("lang") || "").toLowerCase();
      if (htmlLang.indexOf("en") === 0) {
        return "en";
      }
      return "ru";
    }

    function setElementText(element, value) {
      if (!element || element.textContent === value) {
        return;
      }
      element.textContent = value;
    }

    function loadWidgetScript() {
      if (window.ChatMeWidget) {
        return Promise.resolve();
      }

      if (window.__insalesChatMeScriptPromise__) {
        return window.__insalesChatMeScriptPromise__;
      }

      window.__insalesChatMeScriptPromise__ = new Promise(function (resolve, reject) {
        var existing = document.querySelector('script[data-chat-me-widget="insales-iwant"]');
        if (existing) {
          existing.addEventListener("load", function () { resolve(); }, { once: true });
          existing.addEventListener("error", function () { reject(new Error("chat-me widget failed to load")); }, { once: true });
          return;
        }

        var script = document.createElement("script");
        script.src = CHAT_WIDGET_URL;
        script.async = true;
        script.defer = true;
        script.dataset.chatMeWidget = "insales-iwant";
        script.onload = function () { resolve(); };
        script.onerror = function () {
          window.__insalesChatMeScriptPromise__ = null;
          script.remove();
          reject(new Error("chat-me widget failed to load"));
        };
        document.head.appendChild(script);
      });

      return window.__insalesChatMeScriptPromise__;
    }

    function applyEnhancements(target) {
      var shadowRoot = target.shadowRoot;
      if (!shadowRoot) {
        return function () {};
      }

      var locale = getLocale();
      var copy = widgetCopy[locale] || widgetCopy.ru;

      function sync() {
        var styleTag = shadowRoot.querySelector("#insales-iwant-chat-overrides");
        if (!styleTag) {
          styleTag = document.createElement("style");
          styleTag.id = "insales-iwant-chat-overrides";
          shadowRoot.appendChild(styleTag);
        }

        if (styleTag.textContent !== widgetOverrideStyles) {
          styleTag.textContent = widgetOverrideStyles;
        }

        var root = shadowRoot.querySelector(".chat-me");
        if (!root) {
          return;
        }

        root.dataset.locale = locale;
        root.lang = locale;

        setElementText(shadowRoot.querySelector(".chat-me__eyebrow"), copy.eyebrowLabel);
        setElementText(shadowRoot.querySelector(".chat-me__title"), copy.title);
        setElementText(shadowRoot.querySelector(".chat-me__subtitle"), copy.subtitle);
        setElementText(shadowRoot.querySelector(".chat-me__empty"), copy.emptyLabel);
        setElementText(shadowRoot.querySelector(".chat-me__privacy"), copy.privacyLabel);
        setElementText(shadowRoot.querySelector(".chat-me__lead-title"), copy.leadTitle);
        setElementText(shadowRoot.querySelector(".chat-me__composer-note"), copy.leadLockedPlaceholder);

        var leadCard = shadowRoot.querySelector(".chat-me__lead-card");
        var leadText = shadowRoot.querySelector(".chat-me__lead-text");
        var leadSuccess = shadowRoot.querySelector(".chat-me__lead-success");

        if (leadCard && leadCard.classList.contains("is-saved")) {
          setElementText(leadSuccess, copy.leadSaved);
        } else {
          setElementText(leadText, copy.leadHint);
        }

        var closeButton = shadowRoot.querySelector(".chat-me__close");
        var leadSaveButton = shadowRoot.querySelector(".chat-me__lead-save");
        var sendButton = shadowRoot.querySelector(".chat-me__send");
        var textarea = shadowRoot.querySelector(".chat-me__textarea");
        var nameInput = shadowRoot.querySelector("input[name='visitor-name']");
        var contactInput = shadowRoot.querySelector("input[name='visitor-contact']");

        if (closeButton) {
          closeButton.setAttribute("aria-label", copy.closeLabel);
          closeButton.setAttribute("title", copy.closeLabel);
        }

        setElementText(leadSaveButton, copy.leadSave);

        if (sendButton) {
          setElementText(sendButton, sendButton.disabled ? copy.sendPendingLabel : copy.sendLabel);
        }

        if (textarea && textarea.getAttribute("placeholder") !== copy.placeholder) {
          textarea.setAttribute("placeholder", copy.placeholder);
        }

        if (nameInput && nameInput.getAttribute("placeholder") !== copy.nameLabel) {
          nameInput.setAttribute("placeholder", copy.nameLabel);
        }

        if (contactInput && contactInput.getAttribute("placeholder") !== copy.contactLabel) {
          contactInput.setAttribute("placeholder", copy.contactLabel);
        }

        var status = shadowRoot.querySelector(".chat-me__status");
        if (status) {
          var current = (status.textContent || "").trim();

          if (!current) {
            status.textContent = copy.statusIdle;
          } else if (/подключ|connect/i.test(current)) {
            status.textContent = copy.statusConnecting;
          } else if (/переподключ|reconnect/i.test(current)) {
            status.textContent = copy.statusOffline;
          }
        }

        var bubbles = shadowRoot.querySelectorAll(".chat-me__bubble");
        Array.prototype.forEach.call(bubbles, function (bubble) {
          var authorLabel = copy.operatorMessageLabel;
          if (bubble.classList.contains("visitor")) {
            authorLabel = copy.visitorMessageLabel;
          } else if (bubble.classList.contains("system")) {
            authorLabel = copy.systemMessageLabel;
          }
          if (bubble.getAttribute("data-author-label") !== authorLabel) {
            bubble.setAttribute("data-author-label", authorLabel);
          }
        });
      }

      sync();

      var frameId = 0;
      var observer = new MutationObserver(function () {
        if (frameId) {
          cancelAnimationFrame(frameId);
        }
        frameId = requestAnimationFrame(sync);
      });

      observer.observe(shadowRoot, {
        childList: true,
        subtree: true
      });

      return function () {
        observer.disconnect();
        if (frameId) {
          cancelAnimationFrame(frameId);
        }
      };
    }

    function openChat() {
      window.__insalesChatMeOpenRequested__ = true;
      if (window.__insalesChatMeController__) {
        window.__insalesChatMeController__.open();
        window.__insalesChatMeOpenRequested__ = false;
      }
    }

    function bindTriggers() {
      var triggers = document.querySelectorAll("[data-chat-me-trigger]");
      Array.prototype.forEach.call(triggers, function (trigger) {
        if (trigger.dataset.chatMeBound === "true") {
          return;
        }

        trigger.dataset.chatMeBound = "true";
        trigger.addEventListener("click", function (event) {
          event.preventDefault();
          openChat();
        });
      });
    }

    function mountWidget() {
      loadWidgetScript()
        .then(function () {
          if (!window.ChatMeWidget) {
            return;
          }

          var target = document.getElementById(TARGET_ID);
          if (!target) {
            return;
          }

          var copy = widgetCopy[getLocale()] || widgetCopy.ru;

          if (window.__insalesChatMeCleanupEnhancements__) {
            window.__insalesChatMeCleanupEnhancements__();
            window.__insalesChatMeCleanupEnhancements__ = null;
          }

          if (window.__insalesChatMeController__) {
            window.__insalesChatMeController__.destroy();
            window.__insalesChatMeController__ = null;
          }

          window.__insalesChatMeController__ = window.ChatMeWidget.init({
            target: target,
            projectKey: CHAT_PROJECT_KEY,
            apiBaseUrl: CHAT_API_BASE_URL,
            locale: getLocale(),
            privacyUrl: PRIVACY_URL,
            initialGreeting: copy.initialGreeting,
            theme: {
              accentColor: "#ffffff",
              buttonLabel: copy.buttonLabel,
              position: "bottom-right",
              borderRadius: 26
            }
          });

          window.__insalesChatMeCleanupEnhancements__ = applyEnhancements(target);

          if (window.__insalesChatMeOpenRequested__) {
            window.__insalesChatMeController__.open();
            window.__insalesChatMeOpenRequested__ = false;
          }
        })
        .catch(function () {
          return;
        });
    }

    function start() {
      bindTriggers();
      mountWidget();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", start, { once: true });
    } else {
      start();
    }
  })();
</script>

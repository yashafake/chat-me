{%- comment -%}
  IWANT / InSales / Liquid integration for chat-me.

  How to use:
  1. Include this snippet once in the theme.
  2. Any link or button with `href="#shop-chat"` or `data-chat-me-trigger` will open chat.
  3. Optional: `data-chat-me-draft="..."` pre-fills the first message.
  4. If your privacy policy page has a custom URL, replace `PRIVACY_URL` below.
{%- endcomment -%}

<div class="contact-float-group{% if template == 'product' %} product-page-btns{% endif %}">
  <a
    href="#shop-chat"
    rel="nofollow noopener"
    class="contact-fix-btn"
    data-chat-me-trigger
    aria-label="Открыть чат с магазином"
  >
    Чат
  </a>
</div>

<div id="insales-chat-me-root" aria-hidden="true"></div>

